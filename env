#--------------------------------------------------------------------
# ROUTER CONTROL — GenieACS (TR-069) NBI
#--------------------------------------------------------------------
# Northbound Interface base URL. The NBI has NO auth — keep it on loopback
# (or behind an authenticated reverse proxy); never expose port 7557.
# Leave unset to disable TR-069 (the app then uses the WebView guided fallback).

# genieacs.nbiUrl = 'http://127.0.0.1:7557'
# genieacs.taskTimeoutMs = 3000

#--------------------------------------------------------------------
# ROUTER CONTROL — Vendor cloud APIs (home CPE, per brand)
#--------------------------------------------------------------------
# Home routers sit on a private LAN IP unreachable from this backend, so a
# vendor handler must use the brand's CLOUD API. Configure per brand (lowercase):
# leave unset to disable that brand (the app then uses the WebView fallback).

# vendor.tplink.apiUrl = 'https://cloud.example-tplink/api'
# vendor.tplink.apiKey = ''
# vendor.tenda.apiUrl = ''
# vendor.tenda.apiKey = ''

#--------------------------------------------------------------------
# MULTI-TENANCY (SaaS subdomain portals)
#--------------------------------------------------------------------
# Master switch. false (default) = every request is treated as the platform
# app: no subdomain/slug lookup, no tenant branding, no suspended-portal
# blocking, and the Tenant Portals admin screens (/tenants/*) are disabled.
# Can also be flipped at runtime without a deploy via setFlag('tenant_enabled', true).
# TENANT_ENABLED = false

#--------------------------------------------------------------------
# BACKGROUND QUEUE — `php spark queue:work` (Phase 3 / MT-2)
#--------------------------------------------------------------------
# Heavy external I/O (SMS blasts, router provisioning) can be offloaded to the
# DB-backed job queue, drained by a `php spark queue:work` worker, instead of
# running inline on the request. Both flags default OFF — behaviour is unchanged
# until you turn them on AND have a worker running. Validate on staging first.

# Enqueue the All-Customers SMS blast instead of sending inline. Requires the
# per-tenant SMS gateway to resolve in CLI (no session) — verify on staging.
# queue.smsEnabled = false

# Offload the bKash webhook's MikroTik enable to the worker (persist->ACK->enqueue):
# the webhook returns fast and the worker enables the line with retry/backoff
# behind the router circuit breaker. OFF = the original synchronous enable runs
# inline (unchanged). Turn ON only after a staging bKash callback confirms the
# queued path enables a real connection.
# queue.webhookRouterEnabled = false
