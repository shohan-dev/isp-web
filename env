# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.cookieName = 'ci_session'
# session.expiration = 7200
# session.savePath = null
# session.matchIP = false
# session.timeToUpdate = 300
# session.regenerateDestroy = false

# Redis sessions on a MANAGED/EXTERNAL store (Upstash etc.) — TLS, single DB 0.
# savePath is a DSN: tls:// scheme = TLS connect; auth=<token>; keep prefix= LAST.
# Unlike the cache there is NO auto-fallback — if Redis is unreachable, sessions
# fail, so the host MUST have phpredis >= 5.3 (OpenSSL). To REVERT to file
# sessions you MUST do BOTH: set driver back to FileHandler AND comment out
# session.savePath below — FileHandler runs mkdir() on savePath, so leaving the
# tls:// DSN there makes it fatal too. Use an Upstash region close to the app
# server (per-request RTT).
# session.driver   = 'CodeIgniter\Session\Handlers\RedisHandler'
# session.savePath = 'tls://YOUR-ID.upstash.io:6379?timeout=1.5&auth=YOUR_UPSTASH_TOKEN&database=0&prefix=isp_sess:'

#--------------------------------------------------------------------
# CACHE / REDIS  (dynamic — binds onto Config\Cache exactly like database.default.*)
#--------------------------------------------------------------------
# Local self-hosted Redis (see deploy/redis.conf):
# cache.handler        = 'redis'
# cache.redis.host     = '127.0.0.1'
# cache.redis.port     = 6379
# cache.redis.password = 'CHANGE_ME_STRONG_REDIS_PASSWORD'
# cache.redis.database = 0
# cache.redis.timeout  = 1.0
#
# Managed/external Redis (Upstash) — host gets the tls:// scheme so phpredis
# connects over TLS; Upstash is single-DB so keep database=0 (SELECT to 1/2/3 is
# unsupported) and rely on key prefixes (cache=ispc:, session=isp_sess:). A Redis
# stall degrades to the file cache (Config\Cache::$backupHandler='file').
# cache.handler        = 'redis'
# cache.redis.host     = 'tls://YOUR-ID.upstash.io'
# cache.redis.port     = 6379
# cache.redis.password = 'YOUR_UPSTASH_TOKEN'
# cache.redis.database = 0
# cache.redis.timeout  = 1.5
# cache.prefix         = 'ispc:'

