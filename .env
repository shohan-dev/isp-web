#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------

security.csrfProtection = 'session'
security.tokenRandomize = false
security.tokenName = 'app_csrf_token'
security.headerName = 'X-CSRF-TOKEN'
security.cookieName = 'app_csrf_cookie'
security.expires = 7200
security.regenerate = false
security.redirect = false
security.samesite = 'Lax'

#--------------------------------------------------------------------
# SESSION + CACHE — local Redis via Predis (pure PHP, no phpredis ext)
# Start local Redis: sudo service redis-server start  |  redis-cli ping → PONG
# On prod with phpredis you may use RedisHandler + cache.handler = redis instead.
#
# redis.enabled = false  → cache + sessions use files only (no Redis required)
# redis.enabled = true   → uses cache.handler + session.driver below
#--------------------------------------------------------------------

redis.enabled = false

session.driver = 'App\Session\Handlers\PredisHandler'
session.cookieName = 'ci_session'
session.expiration = 7200
session.savePath = 'tcp://127.0.0.1:6379?timeout=1.0&database=0&prefix=isp_sess:'
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = false

cache.handler        = 'predis'
cache.redis.host     = '127.0.0.1'
cache.redis.port     = 6379
cache.redis.password =
cache.redis.database = 0
cache.redis.timeout  = 1.0

